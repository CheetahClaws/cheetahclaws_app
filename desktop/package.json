{
  "name": "cheetahclaws-desktop",
  "productName": "CheetahClaws",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop shell for CheetahClaws — wraps the local web UI in a native window",
  "license": "Apache-2.0",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "smoke": "node test/sidecar.smoke.js",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ai.saferl.cheetahclaws",
    "productName": "CheetahClaws",
    "files": [
      "src/**/*"
    ],
    "directories": {
      "output": "out"
    },
    "mac": { "target": "dmg", "category": "public.app-category.developer-tools" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage", "category": "Development" }
  }
}
